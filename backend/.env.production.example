# ─── Core ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── Database ───────────────────────────────────────────────────────────────
# Use MongoDB Atlas connection string in production
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fitrack?retryWrites=true&w=majority

# ─── Auth Secrets (generate with: openssl rand -base64 64) ──────────────────
JWT_ACCESS_SECRET=replace-with-64-char-random-secret
JWT_REFRESH_SECRET=replace-with-64-char-random-secret

# ─── Field Encryption (exactly 32 characters) ───────────────────────────────
FIELD_ENCRYPTION_KEY=replace-with-exactly-32-char-key!

# ─── CORS ───────────────────────────────────────────────────────────────────
CLIENT_URL=https://your-frontend-domain.com

# ─── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Cloudinary ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── AWS S3 (for MongoDB backups) ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=us-east-1
S3_BUCKET_NAME=fitrack-backups

# ─── Sentry (optional — activates when set) ─────────────────────────────────
SENTRY_DSN=https://<key>@sentry.io/<project>

# ─── PM2 ────────────────────────────────────────────────────────────────────
APP_NAME=fitrack-backend
